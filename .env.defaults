# Valores compartidos por el equipo (sin secretos). Se cargan antes que `.env`.
# Copia o edita `.env` para secretos (JWT, Oracle, etc.).

# URL base de un API donde ya existan las fotos bajo /uploads/profiles/
# (sin barra final). Si está definida, quien clona el repo y corre `npm run dev`
# verá las imágenes aunque su carpeta uploads/ esté vacía: el backend las
# descarga una vez y las guarda en local.
# Ejemplo: PROFILE_PHOTOS_REMOTE_BASE=https://api.midominio.com
PROFILE_PHOTOS_REMOTE_BASE=
